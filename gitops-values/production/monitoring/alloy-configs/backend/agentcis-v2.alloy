// agentcis-v2.alloy
declare "run" {
  argument "loki_receiver" {}
  local.file_match "agentcis_v2" {
    path_targets = [
      { "__path__" = "/var/log/nfs/agentcis-v2/agentcis-v2-crm-frontend/**/*.log" },
      { "__path__" = "/var/log/nfs/agentcis-v2/proxy-webserver/**/*.log" },
    ]
    sync_period = "10s"
  }
  loki.source.file "agentcis_v2" {
    targets       = local.file_match.agentcis_v2.targets
    forward_to    = [loki.process.agentcis_v2.receiver]
    tail_from_end = false
  }
  loki.process "agentcis_v2" {
    stage.static_labels {
      values = {
        job       = "kubernetes-pods",
        namespace = "agentcis-v2",
      }
    }
    forward_to = [argument.loki_receiver.value]
  }
}